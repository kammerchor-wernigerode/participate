root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false
max_line_length = 80

[*.java]
max_line_length = 120

[*.{yml,yaml,json}]
indent_size = 2

[*.iml]
insert_final_newline = false
