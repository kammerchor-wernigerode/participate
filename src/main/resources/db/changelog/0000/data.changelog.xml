<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd"
    logicalFilePath="de/vinado/wicket/participate/db/liquibase/0000/data.changelog.xml"
>

    <include relativeToChangelogFile="true" file="data/c_list_of_value.xml"/>
    <include relativeToChangelogFile="true" file="data/persons.xml"/>
    <include relativeToChangelogFile="true" file="data/roles.xml"/>
    <include relativeToChangelogFile="true" file="data/m_person_role.xml"/>
    <include relativeToChangelogFile="true" file="data/m_role_permission.xml"/>
    <include relativeToChangelogFile="true" file="data/users.xml"/>
    <include relativeToChangelogFile="true" file="data/members.xml"/>
    <include relativeToChangelogFile="true" file="data/groups.xml"/>
    <include relativeToChangelogFile="true" file="data/m_member_group.xml"/>

    <changeSet id="0000-data-delete_default_users" author="Vincent Nadoll">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="2">
                SELECT COUNT(*)
                FROM persons
            </sqlCheck>
        </preConditions>

        <delete tableName="m_member_group"/>
        <delete tableName="members"/>
        <delete tableName="users"/>
        <delete tableName="m_person_role"/>
        <delete tableName="persons"/>
    </changeSet>

</databaseChangeLog>
